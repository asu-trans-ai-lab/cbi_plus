# outputs & caches — the repo ships code + docs only, never data or run artifacts
__pycache__/
*.pyc
outputs/
*.png
*.parquet
*.zip
_inputs/
# large adapter intermediates
tfb_*.json
# local editor/OS noise
.vscode/
.idea/
Thumbs.db
.DS_Store

# review-materials drop (raw previous versions, 131MB INRIX I-17 etc.) — reference only
additional/

# EXCEPTION: benchmark evidence figures are the deliverable — keep them tracked
!benchmarks/**/*.png
!docs/figures/*.png
